TESSER_BASE_URL=https://sandbox.tesserx.co
TESSER_AUTH_URL=https://dev-awqy75wdabpsnsvu.us.auth0.com/oauth/token
DEBUG_MODE=false

# Get this from the Tesser sandbox dashboard
TESSER_CLIENT_ID=
TESSER_CLIENT_SECRET=

# webhook.site token used by src/webhooks.ts to poll captured events.
# Manage at https://webhook.site (the token is the path segment of your unique URL).
# Single shared URL across tests — cross-test pollution is prevented by
# resource-ID filtering in src/webhooks.ts.
WEBHOOK_SITE_TOKEN=

# API key for the webhook.site account that owns the token above.
# Required when the token is owned by a paid account (require_auth=true).
# Free/anonymous tokens do not need this. Find it at https://webhook.site/#!/settings
WEBHOOK_SITE_API_KEY=

# Beneficiary wallet addresses for the payout test.
# One address per address-class — EVM chains (Ethereum, Polygon, Base, etc.)
# share `_EVM` because they all use 0x... addresses.
# Networks without a configured address are skipped in tests.
#
# BENEFICIARY_WALLET_ADDRESS_STELLAR is a Stellar account with a USDC trustline.
# BENEFICIARY_WALLET_ADDRESS_EVM     is a 0x... Ethereum/EVM address.
BENEFICIARY_WALLET_ADDRESS_STELLAR=
BENEFICIARY_WALLET_ADDRESS_EVM=

# Legacy single-network var (Stellar). Kept for backwards compat — used when
# BENEFICIARY_WALLET_ADDRESS_STELLAR is not set.
BENEFICIARY_WALLET_ADDRESS=GCE5TKW3KAJJB3DPKXFWRIAKJEVOW6BDFGO6R4NRWS2JSZWRYNB2NKQG

# Circle Mint API key — stored in the Tesser vault on first run.
CIRCLE_API_KEY=
